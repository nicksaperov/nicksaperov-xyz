{
  "displayName": "Next.js SSR Failure Alert",
  "combiner": "OR",
  "conditions": [
    {
      "displayName": "SSR 500 Error Detected",
      "conditionThreshold": {
        "filter": "metric.type=\"logging.googleapis.com/user/nextjs_ssr_500_errors\" AND resource.type=\"cloud_run_revision\"",
        "comparison": "COMPARISON_GT",
        "thresholdValue": 0,
        "duration": "0s",
        "aggregations": [
          {
            "alignmentPeriod": "60s",
            "perSeriesAligner": "ALIGN_COUNT"
          }
        ]
      }
    }
  ]
}
